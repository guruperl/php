{
    "name": "genelet/php",
    "description": "PHP version of Genelet web development framework",
    "license": "LGPL-2.1-only",
    "type": "project",
    "authors": [
        {
            "name": "Greetingland, LLC",
            "email": "genelet@gmail.com"
        }
    ],
    "require": {
        "twig/twig": "^3.0",
        "psr/log": "^1.1",
        "psr/simple-cache": "^1.0",
		"guzzlehttp/guzzle": "~6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4" : {
            "Genelet\\" : "src/"
        }
    },
    "autoload-dev": {
        "psr-4" : {
            "Genelet\\Tests\\" : "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --bootstrap vendor/autoload.php tests",
        "test:docker": "./scripts/test-docker.sh",
        "test:sample": "./scripts/test-sample-project-php.sh"
    }
}
